# hex-events install smoke test
# Usage: docker build -t hex-events-test -f tests/Dockerfile.install .
#        docker run --rm hex-events-test
FROM python:3.12-slim

# Skip macOS LaunchAgent/launchctl setup in Docker
ENV HEX_EVENTS_NO_LAUNCHCTL=1

WORKDIR /app

# Install git and procps (pgrep) — needed by tests
RUN apt-get update && apt-get install -y --no-install-recommends git procps && rm -rf /var/lib/apt/lists/*

# Configure git identity at system level so it's found even when HOME is overridden in tests
RUN git config --system user.email "test@test.com" && git config --system user.name "Test"

# Copy entire repo into container
COPY . /app/

# Run the install script
RUN bash install.sh

# smoke_test.sh is already present inside /app/tests/ after the COPY above
CMD ["bash", "tests/smoke_test.sh"]
